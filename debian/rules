#!/usr/bin/make -f
PKG_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/~.*//')
PKG_SOURCE  := $(shell jq -r '.name' composer.json)
PKG_TYPE    := $(shell jq -r '.type' composer.json)

%:
	dh $@

override_dh_clean:
	dh_clean
	rm -rf vendor composer.lock
	rm -rf debian/tmp/

override_dh_auto_test:
	appstreamcli validate --pedantic --no-net \
	    debian/io.github.spoje_net.cnb_cache.metainfo.xml

override_dh_install:
	mkdir -p debian/tmp/
	jq '.version = "$(PKG_VERSION)"' debian/conf/composer.json > debian/tmp/composer.json
	dh_install
	install -m 644 debian/autoload.php debian/cnb-cache/usr/lib/cnb-cache/autoload.php
	sed -i "s|require_once '../vendor/autoload.php'|require_once '/usr/lib/cnb-cache/autoload.php'|" \
	    debian/cnb-cache/usr/lib/cnb-cache/init.php \
	    debian/cnb-cache/usr/lib/cnb-cache/update.php \
	    debian/cnb-cache/usr/share/cnb-cache/index.php
	sed -i -e 's/\.\.\/\.env/\/etc\/cnb-cache\/cnb-cache\.env/g' debian/cnb-cache/usr/*/cnb-cache/*.php
	sed -i "1a defined('APP_NAME') || define('APP_NAME', '$(PKG_SOURCE)');" \
	    debian/cnb-cache/usr/lib/cnb-cache/autoload.php
	sed -i "s|'unknown'|'$(PKG_SOURCE)'|" \
	    debian/cnb-cache/usr/lib/cnb-cache/autoload.php
	sed -i "s|'0.0.0'|'$(PKG_VERSION)'|" \
	    debian/cnb-cache/usr/lib/cnb-cache/autoload.php
	sed -i "s|'library'|'$(PKG_TYPE)'|g" \
	    debian/cnb-cache/usr/lib/cnb-cache/autoload.php
	sed -i "2a defined('APP_VERSION') || define('APP_VERSION', '$(PKG_VERSION)');" \
	    debian/cnb-cache/usr/lib/cnb-cache/autoload.php
	mkdir -p                                                             debian/cnb-cache-sqlite/usr/lib/cnb-cache
	cp debian/conf/.env.template                                         debian/cnb-cache-sqlite/usr/lib/cnb-cache
	mkdir -p                                                             debian/cnb-cache-mysql/usr/lib/cnb-cache
	cp debian/conf/.env.template                                         debian/cnb-cache-mysql/usr/lib/cnb-cache
	mkdir -p                                                             debian/cnb-cache-pgsql/usr/lib/cnb-cache
	cp debian/conf/.env.template                                         debian/cnb-cache-pgsql/usr/lib/cnb-cache
	sed -i '/DB_DATABASE/c\DB_DATABASE=_DBC_DBNAME_'                     debian/cnb-cache-*sql/usr/lib/cnb-cache/.env.template
